import os
import sys
import platform
import subprocess


# =============================================================================
# SCons Environment
# =============================================================================

Import('env')

with open(env['PROJECT_TOOL_S'], encoding='utf-8') as f:
    exec(f.read())


# =============================================================================
# Constants
# =============================================================================

SYSTEM = platform.system()
IS_DARWIN = SYSTEM == 'Darwin'
IS_DESKTOP_SDL = 'CONFIG_V9_5_LV_USE_SDL' in os.environ

CONFIG_TOOLCHAIN_SYSROOT = os.environ.get('CONFIG_TOOLCHAIN_SYSROOT')
CONFIG_TOOLCHAIN_PREFIX = os.environ.get('CONFIG_TOOLCHAIN_PREFIX')


# =============================================================================
# Helper Functions
# =============================================================================

def run_script(script):
    """
    Run a Python script with its directory as cwd.
    """
    script_path = os.path.abspath(str(AFile(script)))
    script_dir = os.path.dirname(script_path)

    result = subprocess.run(
        [sys.executable, script_path],
        cwd=script_dir,
        capture_output=True,
        text=True,
    )

    if result.returncode != 0:
        if result.stdout:
            print(result.stdout)
        if result.stderr:
            print(result.stderr)
        raise RuntimeError(f'Failed to run script: {script_path}')


def pkg_config_flags(package, option):
    """
    Get flags from pkg-config.

    Example:
        pkg_config_flags('sdl2', '--cflags')
        pkg_config_flags('freetype2', '--libs')
    """
    return subprocess.check_output(
        ['pkg-config', option, package],
        text=True,
    ).strip()


def pkg_config_include_dirs(package, fallback=None):
    """
    Get include directories from pkg-config cflags.
    """
    fallback = fallback or []

    try:
        cflags = pkg_config_flags(package, '--cflags')
        return [
            item.replace('-I', '')
            for item in cflags.split()
            if item.startswith('-I')
        ]
    except Exception:
        return fallback


def pkg_config_libs(package, fallback=None):
    """
    Get linker flags from pkg-config libs.
    """
    fallback = fallback or []

    try:
        libs = pkg_config_flags(package, '--libs')
        return libs.split()
    except Exception:
        return fallback


def get_lvgl_component():
    """
    Find lvgl_component from env['COMPONENTS'].
    """
    for component in env['COMPONENTS']:
        if component['target'] == 'lvgl_component':
            return component

    raise RuntimeError('lvgl_component not found in env["COMPONENTS"]')


def get_sysroot_include_dir():
    if not CONFIG_TOOLCHAIN_SYSROOT:
        return None

    return os.path.join(CONFIG_TOOLCHAIN_SYSROOT, 'usr', 'include')


def get_multiarch_lib_dir():
    if not CONFIG_TOOLCHAIN_SYSROOT:
        return None

    return os.path.join(
        CONFIG_TOOLCHAIN_SYSROOT,
        'usr',
        'lib',
        'aarch64-linux-gnu',
    )


