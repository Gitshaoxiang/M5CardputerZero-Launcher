    env['RANLIB'] = '${_concat(GCCPREFIX, "ranlib", GCCSUFFIX, __env__)}'
    env['RANLIBCOM'] = '$RANLIB $TARGET'
    env['ARFLAGS'] = ['rcs']


# =============================================================================
# Component Basic Config
# =============================================================================

SRCS = Glob('src/*.c*')

INCLUDE = [
    ADir('.'),
    ADir('include'),
]

PRIVATE_INCLUDE = []

STATIC_LIB = []
DYNAMIC_LIB = []

DEFINITIONS = []
DEFINITIONS_PRIVATE = []

LDFLAGS = []
LINK_SEARCH_PATH = []

STATIC_FILES = []


# =============================================================================
# Platform Requirements
# =============================================================================

if IS_DESKTOP_SDL:
    REQUIREMENTS = [
        'lvgl_component',
        'pthread',
    ]
else:
    REQUIREMENTS = [
        'lvgl_component',
        'pthread',
        'input',
        'xkbcommon',
        'udev',
    ]


# =============================================================================
# macOS SDL Desktop Include / Link Flags
# =============================================================================

if IS_DESKTOP_SDL and IS_DARWIN:
    INCLUDE += pkg_config_include_dirs(
        'nlohmann_json',
        fallback=['/opt/homebrew/include'],
    )

    LDFLAGS += pkg_config_libs(
        'freetype2',
        fallback=[
            '-L/opt/homebrew/lib',
            '-lfreetype',
        ],
    )


# =============================================================================
# Linux Cross Compile Link Flags
# =============================================================================

if not IS_DESKTOP_SDL and CONFIG_TOOLCHAIN_SYSROOT:
    multiarch_lib = get_multiarch_lib_dir()

    LDFLAGS += [
        f'-B{multiarch_lib}',
        f'-L{multiarch_lib}',
        f'-Wl,-rpath-link,{multiarch_lib}',
    ]


# =============================================================================
# Source Files
# =============================================================================

SRCS += append_srcs_dir(ADir('ui'))

if IS_DESKTOP_SDL:
    SRCS += Glob('hal/sdl/*.c*')
else:
    SRCS += Glob('hal/linux/*.c*')


# =============================================================================
# LVGL Component Config
# =============================================================================

lvgl_component = get_lvgl_component()

if IS_DESKTOP_SDL:
    lvgl_component['REQUIREMENTS'] += [
        'SDL2',
    ]

    if IS_DARWIN:
        lvgl_component['INCLUDE'] += pkg_config_include_dirs(
            'sdl2',
            fallback=['/opt/homebrew/include/SDL2'],
        )
    else:
        lvgl_component['INCLUDE'] += [
            '/usr/include/SDL2',
        ]

    lvgl_component['DEFINITIONS'] += [
        '-D_REENTRANT',
    ]


# =============================================================================
# LVGL FreeType Config
# =============================================================================

if IS_DESKTOP_SDL and IS_DARWIN:
    lvgl_component['INCLUDE'] += pkg_config_include_dirs(
        'freetype2',
        fallback=['/opt/homebrew/include/freetype2'],
    )
else:
    lvgl_component['REQUIREMENTS'] += [
        'freetype',
    ]

    if CONFIG_TOOLCHAIN_SYSROOT:
        sysroot_include = get_sysroot_include_dir()

        lvgl_component['INCLUDE'] += [
            os.path.join(sysroot_include, 'freetype2'),
            os.path.join(sysroot_include, 'libpng16'),
        ]
    else:
        lvgl_component['INCLUDE'] += [
            '/usr/include/freetype2',
            '/usr/include/libpng16',
        ]


# =============================================================================
# Remove Unused LVGL SDL Keyboard Source
# =============================================================================

lvgl_component['SRCS'] = [
    src
    for src in lvgl_component['SRCS']
    if 'lv_sdl_keyboard.c' not in str(src)
]


