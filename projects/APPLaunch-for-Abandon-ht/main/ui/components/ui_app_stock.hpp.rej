+            sensor_co2eq_ = clampf(sensor_co2eq_ + iaq_step * 8.5f, 400.0f, 2600.0f);
+            sensor_voc_ = clampf(sensor_voc_ + ((rand() % 31) - 15) * 0.01f, 0.05f, 4.0f);
+        }
         if (!sensor_curve_raw_.empty()) {
             sensor_curve_raw_.erase(sensor_curve_raw_.begin());
         }
