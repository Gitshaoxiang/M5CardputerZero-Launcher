+            bme68x_set_op_mode(BME68X_FORCED_MODE, &bme_);
+            uint32_t del_period = bme68x_get_meas_dur(BME68X_FORCED_MODE, &bme_conf_, &bme_) + (bme_heatr_conf_.heatr_dur * 1000);
+            bme_.delay_us(del_period, bme_.intf_ptr);
