from pathlib import Path
import os
import platform
import subprocess
import shutil
import sys

arch = platform.machine()
version = "v0.0.1"
static_lib = "static_lib"
update = False
config_tmp_path = os.path.join("build", "config", "config_tmp.mk")


def _has_cross_toolchain_prefix(path):
    if not os.path.exists(path):
        return False
    try:
        with open(path, "r") as f:
            text = f.read()
        return 'CONFIG_TOOLCHAIN_PREFIX="aarch64-linux-gnu-"' in text
    except Exception:
        return False


def _has_sysroot(path):
    if not os.path.exists(path):
        return False
    try:
        with open(path, "r") as f:
            text = f.read()
        return "CONFIG_TOOLCHAIN_SYSROOT=" in text
    except Exception:
        return False


def _append_sysroot_if_missing(path, sysroot_value):
    if not os.path.exists(path) or _has_sysroot(path):
        return
    with open(path, "a") as f:
        f.write(f'CONFIG_TOOLCHAIN_SYSROOT="{sysroot_value}"\n')

# export CardputerZero=y for cross-compiling to CardputerZero
if "CardputerZero" in os.environ:
    if not os.path.exists(config_tmp_path):
        os.makedirs("build/config", exist_ok=True)
        with open(config_tmp_path, "w") as f:
            f.write("CONFIG_V9_5_LV_USE_LINUX_FBDEV=y\n")
            f.write("CONFIG_V9_5_LV_DRAW_SW_ASM_NEON=y\n")
            f.write("CONFIG_V9_5_LV_USE_DRAW_SW_ASM=1\n")
            f.write("CONFIG_V9_5_LV_USE_EVDEV=y\n")
            f.write('CONFIG_TOOLCHAIN_PREFIX="aarch64-linux-gnu-"\n')
            f.write(f'''CONFIG_TOOLCHAIN_SYSROOT="{os.path.join(sys.path[0], static_lib)}"\n''')

# non-aarch64: SDL simulator
elif arch != "aarch64":
    if not os.path.exists(config_tmp_path):
        os.makedirs("build/config", exist_ok=True)
        with open(config_tmp_path, "w") as f:
            f.write("CONFIG_V9_5_LV_USE_SDL=y\n")
            try:
                sdl2_flags = subprocess.check_output(
                    ["pkg-config", "--cflags", "--libs", "sdl2"], text=True
                ).strip()
                f.write('CONFIG_TOOLCHAIN_FLAGS="{}"\n'.format(sdl2_flags))
            except Exception:
                pass

# aarch64 native: CardputerZero on-device build
else:
    if not os.path.exists(config_tmp_path):
        os.makedirs("build/config", exist_ok=True)
        with open(config_tmp_path, "w") as f:
            f.write("CONFIG_V9_5_LV_USE_LINUX_FBDEV=y\n")
            f.write("CONFIG_V9_5_LV_DRAW_SW_ASM_NEON=y\n")
            f.write("CONFIG_V9_5_LV_USE_DRAW_SW_ASM=1\n")
            f.write("CONFIG_V9_5_LV_USE_EVDEV=y\n")

local_path = Path(os.getcwd())
sdk_path = local_path.parent.parent / "SDK"
os.environ["SDK_PATH"] = str(sdk_path)
os.environ["EXT_COMPONENTS_PATH"] = str(sdk_path.parent / "ext_components")

is_cached_cross_build = _has_cross_toolchain_prefix(config_tmp_path)
if "CardputerZero" in os.environ or is_cached_cross_build:
    # project.py only applies --sysroot when CONFIG_TOOLCHAIN_SYSROOT exists in environment.
    sysroot = os.path.join(sys.path[0], static_lib)
    _append_sysroot_if_missing(config_tmp_path, sysroot)
    os.environ["CONFIG_TOOLCHAIN_SYSROOT"] = sysroot

env = SConscript(
    str(sdk_path / "tools" / "scons" / "project.py"),
    variant_dir=os.getcwd(),
    duplicate=0,
)

if "CardputerZero" in os.environ:
    if not os.path.exists(static_lib):
        update = True
    else:
        try:
            with open(str(Path(static_lib) / "version"), "r") as f:
                if version != f.read().strip():
                    update = True
        except Exception:
            update = True

    if update:
        with open(env["PROJECT_TOOL_S"]) as f:
            exec(f.read())
        down_url = (
            "https://github.com/dianjixz/M5CardputerZero-UserDemo/"
            "releases/download/{}/sdk_bsp.tar.gz"
        ).format(version)
        down_path = check_wget_down(down_url, "static_lib_{}.tar.gz".format(version))
        if os.path.exists(static_lib):
            shutil.rmtree(static_lib)
        shutil.move(down_path, static_lib)
